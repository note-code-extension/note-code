{
	"name": "ncode",
	"displayName": "node-code",
	"description": "A markdown tool note saver extension",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.104.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "ncode.createNotePath",
				"title": "Set or Create Notes Folder"
			},
			{
				"command": "ncode.updateNotePath",
				"title": "Update Notes Folder"
			},
			{
				"command": "ncode.cloneNote",
				"title": "Clone Repository for Notes"
			},
			{
				"command": "ncode.openNote",
				"title": "Open Note"
			},
			{
				"command": "ncode.createNote",
				"title": "Create Note",
				"icon": "$(new-file)"
			},
			{
				"command": "ncode.createFolder",
				"title": "Create Folder",
				"icon": "$(new-folder)"
			},
			{
				"command": "ncode.deleteNote",
				"title": "Delete"
			},
			{
				"command": "ncode.rename",
				"title": "Rename"
			},
			{
				"command": "ncode.refresh",
				"title": "Refresh",
				"icon": "$(refresh)"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "ncode.createNote",
					"when": "view == noteRef",
					"group": "navigation@1"
				},
				{
					"command": "ncode.createFolder",
					"when": "view == noteRef",
					"group": "navigation@2"
				},
				{
					"command": "ncode.refresh",
					"when": "view == noteRef",
					"group": "navigation@3"
				}
			],
			"view/item/context": [
				{
					"command": "ncode.createNote",
					"when": "view == noteRef",
					"group": "crud@1"
				},
				{
					"command": "ncode.createFolder",
					"when": "view == noteRef",
					"group": "crud@2 && viewItem == 'folder'"
				},
				{
					"command": "ncode.rename",
					"when": "view == noteRef",
					"group": "crud@3"
				},
				{
					"command": "ncode.deleteNote",
					"when": "view == noteRef",
					"group": "crud@4"
				}
			]
		},
		"views": {
			"noteContainer": [
				{
					"id": "noteRef",
					"name": "Notes",
					"icon": "$(notebook)"
				},
				{
					"id": "settingsRef",
					"name": "Settings",
					"type": "webview",
					"icon": "$(settings)"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "noteContainer",
					"title": "Sample test",
					"icon": "$(notebook)"
				}
			]
		},
		"configuration": {
			"title": "Note Code",
			"properties": {
				"ncode.notePath": {
					"type": "string",
					"default": "",
					"description": "Path of saved notes"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "pnpm run package",
		"compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
		"check-types": "tsc --noEmit",
		"lint": "eslint src",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^5.4.1",
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"@types/vscode": "^1.104.0",
		"@typescript-eslint/eslint-plugin": "^8.42.0",
		"@typescript-eslint/parser": "^8.42.0",
		"@vscode/test-cli": "^0.0.11",
		"@vscode/test-electron": "^2.5.2",
		"esbuild": "^0.25.9",
		"eslint": "^9.34.0",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.6.2",
		"typescript": "^5.9.2"
	}
}
